# ---------------------------------------------------------------------------
# SMA — environment variables (template)
# ---------------------------------------------------------------------------
# Copie este arquivo pra `.env.local` na mesma pasta (`sma/.env.local`).
# `.env.local` é gitignorado e mantém as credenciais reais.
#
# Vite carrega este arquivo via `envDir: "../"` no `sma/app/vite.config.ts`.
# O Bun server lê este mesmo arquivo direto via `process.env`.
# ---------------------------------------------------------------------------

# ---- Clerk (auth) ----------------------------------------------------------
# Console: https://dashboard.clerk.com → projeto "Chief of Staff" → API keys → React
# Restrição de domínio @smarttalks.ai precisa estar configurada no Clerk Dashboard
# (User & Authentication → Restrictions → Restricted email domains)
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Neon Postgres ---------------------------------------------------------
# Console: https://console.neon.tech → projeto "Chief of Staff" → Connection details
# Use a connection string com pooling (formato: postgresql://...?sslmode=require)
DATABASE_URL=

# ---- SMA secrets (libsodium) -----------------------------------------------
# Master key pra encriptar segredos at-rest na DB (Anthropic API keys per-workspace,
# bearer tokens MCP, OAuth refresh tokens não-Anthropic, etc.)
# Gere com: `bun run scripts/gen-master-key.ts` (cria 32 bytes random hex)
SMA_SECRETS_MASTER_KEY=

# ---- App base URL ----------------------------------------------------------
# URL pública do server em dev (o MCP server `sma` é exposto aqui)
SMA_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Variáveis abaixo entram em tickets futuros — deixe vazias por enquanto.
# ---------------------------------------------------------------------------

# ---- Cloudflare R2 (SMA-18) ------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_FILES=sma-files-dev
R2_BUCKET_AUDIO=sma-audio-dev

# ---- OpenAI Whisper (SMA-19, STT) ------------------------------------------
OPENAI_API_KEY=

# ---- Google OAuth (SMA-13, conexões Gmail/Drive/Calendar) ------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connections/google/callback
